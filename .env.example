# Base URL of your local Flowise instance
FLOWISE_API_ENDPOINT=http://localhost:3000

# Bearer token: Flowise > Settings > API Keys. Leave empty if auth is disabled.
FLOWISE_API_KEY=

# "true" registers one tool per chatflow instead of the generic create_prediction
FLOWISE_DYNAMIC=false

# Optional filters (comma-separated ids / regex on chatflow name)
FLOWISE_WHITELIST_ID=
FLOWISE_BLACKLIST_ID=
FLOWISE_WHITELIST_NAME_REGEX=
FLOWISE_BLACKLIST_NAME_REGEX=

LOG_LEVEL=INFO
